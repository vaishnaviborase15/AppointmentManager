@charset "utf-8";

.ExperienceHero-enter { opacity: 0; transform: translateY(-50px); }

.ExperienceHero-enter-active { opacity: 1; transform: none; transition: all=
 400ms ease-out 0s; }

.ExperienceHero-exit { opacity: 1; }

.ExperienceHero-exit-active { opacity: 0; transition: opacity 400ms ease-ou=
t 0s; }
