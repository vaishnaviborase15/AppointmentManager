@charset "utf-8";

@keyframes showShadow {=20
  0% { box-shadow: none; }
  100% { background-color: rgba(255, 255, 255, 0.97); box-shadow: rgba(0, 0=
, 0, 0.1) 0px 1px 20px 0px; }
}

@keyframes hideShadow {=20
  0% { background-color: rgba(255, 255, 255, 0.97); box-shadow: rgba(0, 0, =
0, 0.1) 0px 1px 20px 0px; }
  100% { box-shadow: none; }
}
