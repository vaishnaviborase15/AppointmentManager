x 4px; }

.SaveButton--disabled { cursor: default; }

.SaveButton__background { border-radius: 22px; max-height: inherit; }

.SaveButton__background--lego { border-radius: 22px; }

.SaveButton__background--enabled { background-color: rgb(230, 0, 35); }

.SaveButton__background--enabled:hover { background-color: rgb(173, 8, 27);=
 }

.SaveButton__background--disabled { background-color: rgb(239, 239, 239); }

.SaveButton__label--lego { font-weight: 600; }
