Content-Location: cid:css-a46d3a56-b28e-400f-b832-c2c9e486caa7@mhtml.blink

@charset "utf-8";

@keyframes shopButtonSlideInThenOut {=20
  0% { width: 0px; }
  15% { width: 120.1px; }
  85% { width: 120.1px; }
  100% { width: 0px; }
}

@keyframes revealShopText {=20
  0% { clip-path: inset(0px 100% 0px 0px); }
  100% { clip-path: inset(0px); }
}

@keyframes stelaSlideInThenOut {=20
  0% { opacity: 0; }
  15% { opacity: 0; }
  25% { opacity: 1; }
  50% { opacity: 1; }
  75% { opacity: 1; }
  85% { opacity: 0; }
  100% { opacity: 0; }
}

@keyframes stelaGrowInAndOut {=20
  0% { transform: scale(0); opacity: 0; }
  10% { transform: scale(1); opacity: 1; }
  90% { transform: scale(1); opacity: 1; }
  100% { transform: scale(0); opacity: 0; }
}
